{
  "name": "trellify",
  "version": "1.6.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "apps:build": "turbo run apps:build",
    "be": "pnpm --filter=server",
    "clean": "turbo run clean",
    "cz": "cz",
    "eslint": "pnpm --filter=eslint",
    "fe": "pnpm --filter=client",
    "format": "prettier --check --ignore-unknown .",
    "format:fix": "prettier --write --ignore-unknown .",
    "preinstall": "pnpm dlx only-allow pnpm",
    "knip": "knip",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "ncu": "pnpm update --latest --workspace-root",
    "pkg:build": "turbo run pkg:build",
    "prepare": "node -e \"const cp=require('child_process');try{cp.execSync('git rev-parse --git-dir',{stdio:'ignore'});cp.execSync('lefthook install',{stdio:'inherit'})}catch(e){}\"",
    "shared": "pnpm --filter=shared",
    "start:dev": "turbo run start:dev --parallel",
    "start:prod": "turbo run start:prod --parallel",
    "typecheck": "turbo run typecheck",
    "ui": "pnpm --filter=ui"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@trivago/prettier-plugin-sort-imports": "catalog:",
    "@types/node": "catalog:",
    "@workspace/typescript": "workspace:*",
    "commitizen": "catalog:",
    "cz-git": "catalog:",
    "knip": "catalog:",
    "lefthook": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-packagejson": "catalog:",
    "prettier-plugin-prisma": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": "24.12.0",
    "pnpm": "11.4.0"
  }
}
